{
  "additionalProperties": false,
  "description": "7-field schema matching the project spec.\nid and category are pipeline-assigned metadata; LLM generation omits them.",
  "properties": {
    "question": {
      "maxLength": 500,
      "minLength": 10,
      "title": "Question",
      "type": "string"
    },
    "answer": {
      "maxLength": 5000,
      "minLength": 20,
      "title": "Answer",
      "type": "string"
    },
    "equipment_problem": {
      "maxLength": 300,
      "minLength": 5,
      "title": "Equipment Problem",
      "type": "string"
    },
    "tools_required": {
      "items": {
        "type": "string"
      },
      "maxItems": 20,
      "minItems": 1,
      "title": "Tools Required",
      "type": "array"
    },
    "steps": {
      "items": {
        "type": "string"
      },
      "maxItems": 25,
      "minItems": 3,
      "title": "Steps",
      "type": "array"
    },
    "safety_info": {
      "maxLength": 1000,
      "minLength": 20,
      "title": "Safety Info",
      "type": "string"
    },
    "tips": {
      "items": {
        "type": "string"
      },
      "maxItems": 10,
      "minItems": 1,
      "title": "Tips",
      "type": "array"
    },
    "id": {
      "anyOf": [
        {
          "pattern": "^qa_\\d+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Id"
    },
    "category": {
      "anyOf": [
        {
          "enum": [
            "appliance_repair",
            "general_home_repair",
            "plumbing_repair",
            "electrical_repair",
            "hvac_maintenance"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Category"
    }
  },
  "required": [
    "question",
    "answer",
    "equipment_problem",
    "tools_required",
    "steps",
    "safety_info",
    "tips"
  ],
  "title": "HomeDiyRepairQA",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}