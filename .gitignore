# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Private tooling — not for the public repo
.projectHistory/
.claude/
memory/

# Judge run output — large/transient; captured in git commit messages instead
human/logs/
llm/logs/
automated/logs/

# Derived outputs — ignore chart contents but keep named blog images
# Note: must use charts/* (not charts/) so that ! exceptions can override
charts/*
!charts/baselineHeatmap.png
!charts/beforeAfterPassRate.png
!charts/autoCorrectTerminal.png

# Generated preview file — rebuild locally with docs/preview.py
docs/preview.html

# Backup archives created during resets
generated_data/archive/
prompts/archive/

# Promptfoo viewer temp files
.promptfoo-viewer.log
.promptfoo-viewer.pid

# CLAUDE.md files (project-local AI context)
CLAUDE.md
**/CLAUDE.md

# Pipeline state (session-specific paths and timestamps)
.pipeline_state.json

# Exported label records (generated output, not source)
analysis/

# Misc
.newlineMetadata/
